set(LIBNAME libudfread)
# Extract version
file(STRINGS ${CMAKE_SOURCE_DIR}/tools/depends/target/udfread/UDFREAD-VERSION VER)

string(REGEX MATCH "VERSION=[^ ]*$.*" UDFREAD_VER "${VER}")
list(GET UDFREAD_VER 0 UDFREAD_VER)
string(SUBSTRING "${UDFREAD_VER}" 8 -1 UDFREAD_VER)

set(UDFREAD_BASE_BUILD_DIR ${CMAKE_BINARY_DIR}/${CORE_BUILD_DIR}/${LIBNAME})

set(PKG_PREFIX_BASE_PATH ${CMAKE_SOURCE_DIR}/project/BuildDependencies/${ARCH})
set(UDFREAD_LIBRARY ${PKG_PREFIX_BASE_PATH}/lib/${LIBNAME}${CMAKE_STATIC_LIBRARY_SUFFIX})
set(UDFREAD_INCLUDE_DIR  ${PKG_PREFIX_BASE_PATH}/include)
set(UDFREAD_VERSION ${UDFREAD_VER})

ExternalProject_Add(${LIBNAME}
  GIT_REPOSITORY https://github.com/Paxxi/libudfread
  GIT_TAG 29fcdb5280e5d1778786795b594ec9fc60bf75da
  GIT_SHALLOW ON
  CMAKE_ARGS
      ${ADDITIONAL_ARGS}
      -DCMAKE_BUILD_TYPE=RELEASE
      -DCMAKE_INSTALL_PREFIX=${PKG_PREFIX_BASE_PATH}
  PREFIX  ${UDFREAD_BASE_BUILD_DIR}
  BUILD_COMMAND 
   ${CMAKE_COMMAND} --build ${UDFREAD_BASE_BUILD_DIR}/src/${LIBNAME}-build --config Release
  INSTALL_COMMAND
   ${CMAKE_COMMAND} --install ${UDFREAD_BASE_BUILD_DIR}/src/${LIBNAME}-build --config Release
  BUILD_BYPRODUCTS ${UDFREAD_LIBRARY})

set_target_properties(${LIBNAME} PROPERTIES FOLDER "External Projects")

message("UDFREAD version ${UDFREAD_VERSION}")

include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(${LIBNAME}
                                  REQUIRED_VARS UDFREAD_LIBRARY UDFREAD_INCLUDE_DIR
                                  VERSION_VAR UDFREAD_VERSION)

set(UDFREAD_LIBRARIES ${UDFREAD_LIBRARY})
set(UDFREAD_INCLUDE_DIRS ${UDFREAD_INCLUDE_DIR})
set(UDFREAD_DEFINITIONS -DHAS_UDFREAD=1)
set(UDFREAD_FOUND 1)

mark_as_advanced(UDFREAD_INCLUDE_DIR UDFREAD_LIBRARY)