set(LIBNAME libbluray)

list(APPEND CMAKE_MODULE_PATH ${CMAKE_SOURCE_DIR}/cmake/modules)

find_package(LibXml2 REQUIRED)
find_package(FreeType REQUIRED)
find_package(Iconv REQUIRED)

if(CORE_SYSTEM_NAME STREQUAL windowsstore)
  set(ADDITIONAL_ARGS "-DCMAKE_SYSTEM_NAME=${CMAKE_SYSTEM_NAME}" "-DCMAKE_SYSTEM_VERSION=${CMAKE_SYSTEM_VERSION}")
endif()

# Extract version
file(STRINGS ${CMAKE_SOURCE_DIR}/tools/depends/target/libbluray/LIBBLURAY-VERSION VER)

string(REGEX MATCH "VERSION=[^ ]*$.*" LIBBLURAY_VER "${VER}")
list(GET LIBBLURAY_VER 0 LIBBLURAY_VER)
string(SUBSTRING "${LIBBLURAY_VER}" 8 -1 LIBBLURAY_VER)

string(REGEX MATCH "GIT_REPO=[^ ]*$.*" LIBBLURAY_GIT_REPO "${VER}")
list(GET LIBBLURAY_GIT_REPO 0 LIBBLURAY_GIT_REPO)
string(SUBSTRING "${LIBBLURAY_GIT_REPO}" 9 -1 LIBBLURAY_GIT_REPO)

string(REGEX MATCH "GIT_TAG=[^ ]*$.*" LIBBLURAY_GIT_TAG "${VER}")
list(GET LIBBLURAY_GIT_TAG 0 LIBBLURAY_GIT_TAG)
string(SUBSTRING "${LIBBLURAY_GIT_TAG}" 8 -1 LIBBLURAY_GIT_TAG)

set(BLURAY_BASE_BUILD_DIR ${CMAKE_BINARY_DIR}/${CORE_BUILD_DIR}/${LIBNAME})

set(BLURAY_LIBRARY ${PKG_PREFIX_BASE_PATH}/lib/${LIBNAME}${CMAKE_STATIC_LIBRARY_SUFFIX})
set(BLURAY_BINS 
    ${PKG_PREFIX_BASE_PATH}/bin/${LIBNAME}${CMAKE_SHARED_LIBRARY_SUFFIX}
    ${PKG_PREFIX_BASE_PATH}/bin/libbluray-j2se-${LIBBLURAY_VER}.jar
    ${PKG_PREFIX_BASE_PATH}/bin/libbluray-awt-j2se-${LIBBLURAY_VER}.jar)

set(BLURAY_INCLUDE_DIR ${BLURAY_BASE_BUILD_DIR}/include)

get_filename_component(BUILD_DIR_NAME ${CMAKE_BINARY_DIR} NAME)
set(BLURAY_SRC_SUBDIR ${BLURAY_BASE_BUILD_DIR}/src/${LIBNAME})

set(PKG_PREFIX_BASE_PATH ${CMAKE_SOURCE_DIR}/project/BuildDependencies/${ARCH})

externalproject_add(${LIBNAME}
    DEPENDS libudfread
    GIT_REPOSITORY ${LIBBLURAY_GIT_REPO}
    GIT_TAG ${LIBBLURAY_GIT_TAG}
    GIT_SHALLOW ON
    PREFIX ${BLURAY_BASE_BUILD_DIR}
    PATCH_COMMAND
        ${CMAKE_SOURCE_DIR}/project/BuildDependencies/msys64/usr/bin/bash.exe --login /xbmc/tools/depends/target/libbluray/msys_patcher.sh /xbmc/${BUILD_DIR_NAME}/${CORE_BUILD_DIR}/${LIBNAME}/src/${LIBNAME}
    CMAKE_ARGS
      ${ADDITIONAL_ARGS}
      -DCMAKE_BUILD_TYPE=RELEASE
      -DCMAKE_MODULE_PATH=${CMAKE_SOURCE_DIR}/cmake/modules
      -DCMAKE_INSTALL_PREFIX=${PKG_PREFIX_BASE_PATH}
      -DCMAKE_PREFIX_PATH=${PKG_PREFIX_BASE_PATH}
      -DCMAKE_FIND_PACKAGE_PREFER_CONFIG=TRUE
    BUILD_COMMAND 
      ${CMAKE_COMMAND} --build ${BLURAY_BASE_BUILD_DIR}/src/${LIBNAME}-build --config Release
    INSTALL_COMMAND
      ${CMAKE_COMMAND} --install ${BLURAY_BASE_BUILD_DIR}/src/${LIBNAME}-build --config Release
    BUILD_BYPRODUCTS ${BLURAY_BINS})

install(FILES ${BLURAY_BINS} DESTINATION ${CMAKE_BINARY_DIR})

set_target_properties(${LIBNAME} PROPERTIES FOLDER "External Projects")

set(BLURAY_INCLUDE_DIRS ${BLURAY_INCLUDE_DIR})
set(BLURAY_DEFINITIONS -DHAVE_LIBBLURAY=1)
set(BLURAY_DEFINED 1)
set(BLURAY_FOUND 1)

# todo: improve syntax
if (NOT CORE_PLATFORM_NAME_LC STREQUAL windowsstore)
  list(APPEND BLURAY_DEFINITIONS -DHAVE_LIBBLURAY_BDJ=1)
endif()

if(${BLURAY_LIBRARY} MATCHES ".+\.a$" AND PC_BLURAY_STATIC_LIBRARIES)
  list(APPEND BLURAY_LIBRARIES ${PC_BLURAY_STATIC_LIBRARIES})
endif()

if(NOT TARGET Bluray::Bluray)
  add_library(Bluray::Bluray UNKNOWN IMPORTED)
  if(BLURAY_LIBRARY)
    set_target_properties(Bluray::Bluray PROPERTIES
                                          IMPORTED_LOCATION "${BLURAY_LIBRARY}")
  endif()
  set_target_properties(Bluray::Bluray PROPERTIES
                                        INTERFACE_INCLUDE_DIRECTORIES "${BLURAY_INCLUDE_DIR}"
                                        INTERFACE_COMPILE_DEFINITIONS HAVE_LIBBLURAY=1)
  list(APPEND BLURAY_LIBRARIES ${BLURAY_LIBRARY})
endif()

mark_as_advanced(BLURAY_INCLUDE_DIR BLURAY_LIBRARY)